{# Fixed mobile tab bar — uses Salla events/URLs only (no extra scripts / no cross-origin assets). #}
<nav class="mobile-bottom-nav" aria-label="{{ trans('blocks.footer.mobile_nav_label') }}" data-mobile-bottom-nav>
  <div class="mobile-bottom-nav__inner">
    {% if user.type == 'user' %}
      <a href="{{ store.url }}/profile" class="mobile-bottom-nav__item">
        <span class="mobile-bottom-nav__icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="8" r="3.5" stroke="currentColor" stroke-width="1.5"/><path d="M6 20v-1c0-3 2.5-5 6-5s6 2 6 5v1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span class="mobile-bottom-nav__label">{{ trans('blocks.footer.mobile_nav_account') }}</span>
      </a>
    {% else %}
      <button type="button" class="mobile-bottom-nav__item" onclick="salla.event.dispatch('login::open')">
        <span class="mobile-bottom-nav__icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="8" r="3.5" stroke="currentColor" stroke-width="1.5"/><path d="M6 20v-1c0-3 2.5-5 6-5s6 2 6 5v1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span class="mobile-bottom-nav__label">{{ trans('blocks.footer.mobile_nav_account') }}</span>
      </button>
    {% endif %}

    <a href="{{ store.url }}/categories" class="mobile-bottom-nav__item">
      <span class="mobile-bottom-nav__icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/></svg>
      </span>
      <span class="mobile-bottom-nav__label">{{ trans('blocks.footer.mobile_nav_categories') }}</span>
    </a>

    <button type="button" class="mobile-bottom-nav__item" id="mobile-bottom-nav-car-filter" aria-label="{{ trans('blocks.home.choose_your_car') }}">
      <span class="mobile-bottom-nav__icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5 17h2l1-3h8l1 3h2v-3l-2-5H7L5 14v3Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M7.5 14h9M9 11V9M15 11V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="7.5" cy="17.5" r="1.5" stroke="currentColor" stroke-width="1.5"/><circle cx="16.5" cy="17.5" r="1.5" stroke="currentColor" stroke-width="1.5"/></svg>
      </span>
      <span class="mobile-bottom-nav__label">{{ trans('blocks.footer.mobile_nav_car_filter') }}</span>
    </button>

    <button type="button" class="mobile-bottom-nav__item" id="mobile-bottom-nav-search" aria-label="{{ trans('blocks.footer.mobile_nav_search') }}">
      <span class="mobile-bottom-nav__icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="10.5" cy="10.5" r="6.5" stroke="currentColor" stroke-width="1.5"/><path d="M20 20l-4.5-4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </span>
      <span class="mobile-bottom-nav__label">{{ trans('blocks.footer.mobile_nav_search') }}</span>
    </button>

    <button type="button" class="mobile-bottom-nav__item" id="mobile-bottom-nav-top" aria-label="{{ trans('blocks.footer.mobile_nav_top') }}">
      <span class="mobile-bottom-nav__icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 5l6 6H6l6-6Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
      </span>
      <span class="mobile-bottom-nav__label">{{ trans('blocks.footer.mobile_nav_top') }}</span>
    </button>
  </div>
</nav>
