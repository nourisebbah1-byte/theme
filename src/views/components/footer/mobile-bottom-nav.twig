{# Fixed bottom bar — mobile / tablet only. Uses Salla events & existing header controls. #}
<nav class="mobile-bottom-nav" aria-label="{{ trans('blocks.mobile_nav.nav_label') }}">
  <div class="mobile-bottom-nav__inner">
    {% if user.type == 'user' %}
      <a href="{{ link('customer.profile') }}" class="mobile-bottom-nav__item">
        <span class="mobile-bottom-nav__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </span>
        <span class="mobile-bottom-nav__label">{{ trans('blocks.mobile_nav.account') }}</span>
      </a>
    {% else %}
      <button type="button" class="mobile-bottom-nav__item" onclick="typeof salla !== 'undefined' && salla.event && salla.event.dispatch('login::open')">
        <span class="mobile-bottom-nav__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </span>
        <span class="mobile-bottom-nav__label">{{ trans('blocks.mobile_nav.account') }}</span>
      </button>
    {% endif %}

    <button type="button" class="mobile-bottom-nav__item" id="mobile-bottom-nav-categories" onclick="document.querySelector('a.mburger--collapse')?.click() || document.getElementById('all-categories-btn')?.click()">
      <span class="mobile-bottom-nav__icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      </span>
      <span class="mobile-bottom-nav__label">{{ trans('blocks.mobile_nav.categories') }}</span>
    </button>

    <button type="button" class="mobile-bottom-nav__item" id="mobile-bottom-nav-car-filter" onclick="document.getElementById('vehicle-filter-toggle-btn')?.click()">
      <span class="mobile-bottom-nav__icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
      </span>
      <span class="mobile-bottom-nav__label">{{ trans('blocks.mobile_nav.car_filter') }}</span>
    </button>

    <button type="button" class="mobile-bottom-nav__item" onclick="typeof salla !== 'undefined' && salla.event && salla.event.dispatch('search::open')">
      <span class="mobile-bottom-nav__icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </span>
      <span class="mobile-bottom-nav__label">{{ trans('blocks.mobile_nav.search') }}</span>
    </button>

    <button type="button" class="mobile-bottom-nav__item" onclick="window.scrollTo({ top: 0, behavior: 'smooth' })">
      <span class="mobile-bottom-nav__icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
      </span>
      <span class="mobile-bottom-nav__label">{{ trans('blocks.mobile_nav.top') }}</span>
    </button>
  </div>
</nav>
