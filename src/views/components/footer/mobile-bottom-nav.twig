{# Fixed bottom navigation — mobile only. Reuses Salla login event, customer.profile link, search route, mmenu + vehicle filter buttons (no new .js assets). #}
<nav class="mobile-bottom-nav" aria-label="{{ trans('blocks.mobile_nav.nav_label') }}">
  <div class="mobile-bottom-nav__inner">
    {% if user.type == 'user' %}
      <a href="{{ link('customer.profile') }}" class="mobile-bottom-nav__item">
        <span class="mobile-bottom-nav__icon" aria-hidden="true"><i class="far fa-user"></i></span>
        <span class="mobile-bottom-nav__label">{{ trans('blocks.mobile_nav.account') }}</span>
      </a>
    {% else %}
      <button type="button" class="mobile-bottom-nav__item" onclick="salla.event.dispatch('login::open')">
        <span class="mobile-bottom-nav__icon" aria-hidden="true"><i class="far fa-user"></i></span>
        <span class="mobile-bottom-nav__label">{{ trans('blocks.mobile_nav.account') }}</span>
      </button>
    {% endif %}

    {# Matches all-categories-dropdown.js mobile: opens .mburger--collapse #}
    <button type="button" class="mobile-bottom-nav__item" onclick="document.querySelector('a.mburger--collapse')?.click()">
      <span class="mobile-bottom-nav__icon" aria-hidden="true"><i class="fa-solid fa-border-all"></i></span>
      <span class="mobile-bottom-nav__label">{{ trans('blocks.mobile_nav.categories') }}</span>
    </button>

    <button type="button" class="mobile-bottom-nav__item" onclick="document.getElementById('vehicle-filter-toggle-btn')?.click()" aria-label="{{ trans('blocks.home.choose_your_car') }}">
      <span class="mobile-bottom-nav__icon" aria-hidden="true"><i class="fa-solid fa-car"></i></span>
      <span class="mobile-bottom-nav__label">{{ trans('blocks.mobile_nav.car_filter') }}</span>
    </button>

    <a href="{{ link('/search') }}" class="mobile-bottom-nav__item">
      <span class="mobile-bottom-nav__icon" aria-hidden="true"><i class="fa-solid fa-magnifying-glass"></i></span>
      <span class="mobile-bottom-nav__label">{{ trans('blocks.mobile_nav.search') }}</span>
    </a>

    <button type="button" class="mobile-bottom-nav__item" onclick="window.scrollTo({ top: 0, behavior: 'smooth' })">
      <span class="mobile-bottom-nav__icon" aria-hidden="true"><i class="fa-solid fa-chevron-up"></i></span>
      <span class="mobile-bottom-nav__label">{{ trans('blocks.mobile_nav.top') }}</span>
    </button>
  </div>
</nav>
