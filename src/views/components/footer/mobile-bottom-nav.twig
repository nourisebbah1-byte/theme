{# Fixed bottom bar — mobile / tablet only; uses existing Salla + theme hooks (no extra scripts). #}
<nav class="mobex-mobile-bottom-nav" aria-label="{{ trans('blocks.header.bottom_nav_label') }}">
  {% if user.type == 'user' %}
    <a href="{{ link('customer.orders.index') }}" class="mobex-mobile-bottom-nav__item">
      <span class="mobex-mobile-bottom-nav__icon" aria-hidden="true"><i class="sicon-user-circle"></i></span>
      <span class="mobex-mobile-bottom-nav__label">{{ trans('blocks.header.bottom_nav_account') }}</span>
    </a>
  {% else %}
    <button type="button" class="mobex-mobile-bottom-nav__item" onclick="salla.event.dispatch('login::open')">
      <span class="mobex-mobile-bottom-nav__icon" aria-hidden="true"><i class="sicon-user-circle"></i></span>
      <span class="mobex-mobile-bottom-nav__label">{{ trans('blocks.header.bottom_nav_account') }}</span>
    </button>
  {% endif %}

  <a href="#mobile-menu" class="mobex-mobile-bottom-nav__item">
    <span class="mobex-mobile-bottom-nav__icon" aria-hidden="true"><i class="sicon-menu"></i></span>
    <span class="mobex-mobile-bottom-nav__label">{{ trans('blocks.header.bottom_nav_categories') }}</span>
  </a>

  <button type="button" class="mobex-mobile-bottom-nav__item" aria-label="{{ trans('blocks.home.choose_your_car') }}" onclick="document.getElementById('vehicle-filter-toggle-btn')?.click()">
    <span class="mobex-mobile-bottom-nav__icon mobex-mobile-bottom-nav__icon--car" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M5 17a2 2 0 1 0 4 0 2 2 0 0 0-4 0Zm10 0a2 2 0 1 0 4 0 2 2 0 0 0-4 0Z"/><path d="M5 17H3v-5l2-5h9l4 5h2v5h-2m-4 0H9m-8-5h15"/><path d="m3 12 2-3h11"/></svg>
    </span>
    <span class="mobex-mobile-bottom-nav__label">{{ trans('blocks.header.bottom_nav_car_filter') }}</span>
  </button>

  <button type="button" class="mobex-mobile-bottom-nav__item" onclick="salla.event.dispatch('search::open')">
    <span class="mobex-mobile-bottom-nav__icon" aria-hidden="true"><i class="fas fa-magnifying-glass"></i></span>
    <span class="mobex-mobile-bottom-nav__label">{{ trans('blocks.header.bottom_nav_search') }}</span>
  </button>

  <button type="button" class="mobex-mobile-bottom-nav__item" onclick="window.scrollTo({ top: 0, behavior: 'smooth' })">
    <span class="mobex-mobile-bottom-nav__icon" aria-hidden="true"><i class="fas fa-chevron-up"></i></span>
    <span class="mobex-mobile-bottom-nav__label">{{ trans('blocks.header.bottom_nav_top') }}</span>
  </button>
</nav>
