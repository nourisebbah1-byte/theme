{# Brake System Banner - After Featured Manufacturers #}
<section class="additional-banners">
    <div class="container">
        <div class="banner-grid-2">
            <div class="promo-banner brake-banner" style="background-image: url('https://enovathemes.com/mobex/wp-content/uploads/banner4-back.webp'); background-size: cover; background-position: center;">
                <div class="banner-image">
                    <img src="https://enovathemes.com/mobex/wp-content/uploads/banner9-img.webp" alt="{{ trans('blocks.home.brake_system') }}">
                </div>
                <div class="banner-content">
                    <span class="banner-badge">{{ trans('blocks.home.best_brands') }}</span>
                    <h2>{{ trans('blocks.home.brake_system') }}</h2>
                    <p>{{ trans('blocks.home.we_got_you_covered') }}</p>
                    <p class="banner-subtitle">{{ trans('blocks.home.great_value_always') }}</p>
                    <div class="banner-buttons">
                        <button class="banner-btn">{{ trans('blocks.home.shop_now') }} <i class="sicon-sar"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{# Promotional Banners Grid - Above Footer Features #}
<section class="promotional-banners-grid">
    <div class="container">
        <div class="banners-grid-layout">
            {# Banner 1: Lamps and Lights - Large Left Top Banner #}
            <div class="promo-banner-large lamps-banner" style="background-image: url('https://enovathemes.com/mobex/wp-content/uploads/banner6-back.webp');">
                <div class="banner-overlay"></div>
                <div class="banner-content-wrapper">
                    <span class="banner-badge green">{{ trans('blocks.home.best_brands') }}</span>
                    <h2 class="banner-title-large">{{ trans('blocks.home.lamps_lights') }}</h2>
                    <h3 class="banner-title-mega">{{ trans('blocks.home.mega_sale') }}</h3>
                    <p class="banner-subtitle">{{ trans('blocks.home.models_2023_included') }}</p>
                    <div class="banner-actions">
                        <a href="{{ link('/') }}" class="banner-btn-white">{{ trans('blocks.home.shop_now') }} <i class="sicon-sar"></i></a>
                    </div>
                    <div class="banner-category-link">{{ trans('blocks.home.lamps') }}</div>
                </div>
            </div>

            {# Banner 2: Air Filters - Small Right Top Banner #}
            <div class="promo-banner-small air-filters-banner" style="background-image: url('https://enovathemes.com/mobex/wp-content/uploads/banner7-back.webp');">
                <div class="banner-overlay"></div>
                <div class="banner-image-small">
                    <img src="https://enovathemes.com/mobex/wp-content/uploads/banner12-img.webp" alt="{{ trans('blocks.home.air_filters') }}">
                </div>
                <div class="banner-content-wrapper">
                    <span class="banner-badge red">{{ trans('blocks.home.big_discounts') }}</span>
                    <h2 class="banner-title">{{ trans('blocks.home.air_filters') }}</h2>
                    <p class="banner-description">{{ trans('blocks.home.premium_quality') }}</p>
                    <a href="{{ link('/') }}" class="banner-btn-white">{{ trans('blocks.home.shop_now') }} <i class="sicon-sar"></i></a>
                    <div class="banner-category-link">{{ trans('blocks.home.air_filters_category') }}</div>
                </div>
            </div>

            {# Banner 3: Transmission Fluids - Medium Left Bottom Banner #}
            <div class="promo-banner-medium transmission-banner" style="background-image: url('https://enovathemes.com/mobex/wp-content/uploads/banner9-back.webp');">
                <div class="banner-overlay"></div>
                <span class="banner-badge red-small transmission-badge">{{ trans('blocks.home.fifteen_percent_off') }}</span>
                <div class="banner-image-small">
                    <img src="https://enovathemes.com/mobex/wp-content/uploads/banner14-img.webp" alt="{{ trans('blocks.home.transmission_fluids') }}">
                </div>
                <div class="banner-content-wrapper">
                    <h2 class="banner-title">{{ trans('blocks.home.transmission_fluids') }}</h2>
                    <p class="banner-description">{{ trans('blocks.home.superior_quality_atf') }}</p>
                    <div class="banner-actions">
                        <a href="{{ link('/') }}" class="banner-btn-white">{{ trans('blocks.home.shop_now') }} <i class="sicon-sar"></i></a>
                    </div>
                    <div class="banner-category-link">{{ trans('blocks.home.transmission_fluid') }}</div>
                </div>
            </div>

            {# Banner 4: Care Care Kit - Large Right Bottom Banner #}
            <div class="promo-banner-large care-kit-banner" style="background-image: url('https://enovathemes.com/mobex/wp-content/uploads/banner8-back.webp');">
                <div class="banner-overlay"></div>
                <div class="banner-image-small">
                    <img src="https://enovathemes.com/mobex/wp-content/uploads/banner13-img.webp" alt="{{ trans('blocks.home.care_care_kit') }}">
                </div>
                <div class="banner-content-wrapper">
                    <h2 class="banner-title-large">{{ trans('blocks.home.care_care_kit') }}</h2>
                    <p class="banner-description">{{ trans('blocks.home.keep_clean_shine') }}</p>
                    <a href="{{ link('/') }}" class="banner-btn-white">{{ trans('blocks.home.shop_now') }} <i class="sicon-sar"></i></a>
                </div>
            </div>
        </div>
    </div>
</section>

{# Footer Features Section - Above Footer #}
<section class="footer-features-section">
    <div class="container">
        <div class="footer-features">
            <div class="footer-feature">
                <i class="fas fa-headset"></i>
                <h3>{{ trans('blocks.home.expert_service') }}</h3>
                <p>{{ trans('blocks.home.friendly_team_available') }}</p>
            </div>
            <div class="footer-feature">
                <i class="fas fa-hand-holding-usd"></i>
                <h3>{{ trans('blocks.home.amazing_value') }}</h3>
                <p>{{ trans('blocks.home.brands_you_love') }}</p>
            </div>
            <div class="footer-feature">
                <i class="fas fa-truck"></i>
                <h3>{{ trans('blocks.home.fast_free_shipping') }}</h3>
                <p>{{ trans('blocks.home.shipping_fast_delivery') }}</p>
            </div>
            <div class="footer-feature">
                <i class="fas fa-box"></i>
                <h3>{{ trans('blocks.home.irresistible_selection') }}</h3>
                <p>{{ trans('blocks.home.everything_for_car') }}</p>
            </div>
        </div>
    </div>
</section>

<footer class="store-footer">
	<div aria-label="footer" class="store-footer__inner">
		<div class="container footer-content-grid">
			<div class="lg:col-span-2 rtl:lg:pl-20 ltr:lg:pr-20">
				<div class="footer-logo">
					<a href="{{ link('/') }}" class="flex items-center m-0">
						<h2>{{store.name}}</h2>
					</a>
					{% if store.description %}
						<p class="footer-subtitle">{{ store.description|raw }}</p>
					{% else %}
						<p class="footer-subtitle">AUTO PARTS & ACCESSORIES</p>
					{% endif %}
				</div>

				<div class="social-links-wrapper">
					<salla-social class="block mb-6"></salla-social>
				</div>

				<div class="newsletter">
					<p>{{ trans('blocks.home.newsletter_text') }}</p>
					<div class="newsletter-form">
						<input type="email" placeholder="{{ trans('blocks.home.email_placeholder') }}">
						<button type="submit"><i class="fas fa-arrow-left"></i></button>
					</div>
				</div>

		<div class="flex gap-4">
		  {# trust badges #}
		  <salla-trust-badges {% if theme.settings.get('footer_is_dark') %} dark {% endif %}></salla-trust-badges>
          {# vat #}
          {% if store.settings.tax.number %}
            <div class="flex rtl:space-x-reverse space-x-2 items-end">
              {% if store.settings.tax.certificate %}
                <a class="load-img-onclick" data-modal-id="modal-value-tax" href="#/" alt="{{ store.settings.tax.number }}">
                  <img width="40" height="50" src="{{'images/tax.png' | cdn(70,70)}}" loading="lazy" class="w-10 rounded-sm hover:opacity-80 transition-opacity" alt="value added tax">
                </a>
              {% endif %}
              <div>
                <p class="text-sm text-text-grey mb-1">{{ trans('common.elements.tax_number') }}</p>
                <b class="text-sm">{{ store.settings.tax.number }}</b>
              </div>
            </div>

            {% if store.settings.tax.certificate %}
              <salla-modal sub-title-first sub-title="{{ trans('common.elements.tax_number') }}" modal-title="{{ store.settings.tax.number }}" id="modal-value-tax">
                <div class="flex justify-center max-w-full">
                  <img class="w-full" loading="lazy" 
                  src="{{ store.settings.tax.certificate }}" 
                  alt="{{ store.settings.tax.number }}"/>
                </div>
              </salla-modal>
            {% endif %}
          {% endif %}
        </div>
        </div>

			<div>
				<h3>{{ trans('blocks.footer.pages_links') }}</h3>
				<salla-menu source="footer"></salla-menu>
			</div>

			<div>
				<salla-contacts></salla-contacts>

				<div class="lg:hidden contact-social">
					<salla-social></salla-social>
				</div>
			</div>

			<salla-apps-icons class="lg:col-span-2 rtl:lg:pr-20 ltr:lg:pl-20"></salla-apps-icons>

		</div>
	</div>

	<div class="md:flex items-center justify-between py-4 container text-center">
		<span class="text-sm copyright-text">{% hook copyright %}</span>
		<salla-payments></salla-payments>
	</div>
</footer>
