{# Hero Banner with Vehicle Filter #}
<section class="hero-section">
    <div class="hero-slider">
        <div class="hero-slide active">
            <div class="hero-content">
                <div class="hero-text">
                    <h2>JUMP STARTERS</h2>
                    <p>START BATTERIES IN SECONDS</p>
                    <button class="shop-now-btn">Shop now <i class="sicon-sar"></i></button>
                </div>
                <div class="hero-image">
                    <img src="{{ 'images/slider.png'|asset }}" alt="Hero Banner" onerror="this.src='{{ 'images/placeholder.png'|asset }}'">
                    <div class="price-badge">FROM $49.99</div>
                </div>
            </div>
        </div>
    </div>
    
    {# Vehicle Filter - Fixed in Hero Banner #}
    <div class="hero-vehicle-filter">
        <div class="vehicle-filter-form">
            <h5>Select your car</h5>
            <div class="vehicle-filter-fields vehicle-filter-fields--2x2">
                <select class="vehicle-select" id="vehicle-brand">
                    <option value="">Make</option>
                </select>
                <select class="vehicle-select" id="vehicle-model" disabled>
                    <option value="">Model</option>
                </select>
                <select class="vehicle-select" id="vehicle-year" disabled>
                    <option value="">Year</option>
                </select>
                <button type="button" class="vehicle-search-btn" id="vehicle-search-btn">Search</button>
            </div>
            <div class="vehicle-filter-or">
                <span>OR</span>
            </div>
            <div class="vehicle-filter-vin">
                <input type="text" class="vin-input" placeholder="Search by VIN">
                <button class="vin-search-btn">Search</button>
            </div>
        </div>
    </div>
    
    <div class="slider-dots">
        <span class="dot active"></span>
        <span class="dot"></span>
        <span class="dot"></span>
    </div>
</section>
