                    <p class="mobex-et-heading mobex-et-sub"><span class="text">{{ trans('blocks.home.superior_quality_atf') }}</span></p>
                    <a href="{{ shop }}" class="mobex-promo-cta"><span class="text">{{ trans('blocks.home.shop_now') }}</span><span class="mobex-promo-cta-arrow" aria-hidden="true"></span></a>
                </div>
                <div class="mobex-promo-media mobex-promo-media--b13">
                    <div class="et-image"><img src="{{ 'images/mobex-banners/banner13-img.webp'|asset }}" width="301" height="240" alt="" loading="lazy" decoding="async"></div>
                </div>
            </div>
            <div class="mobex-promo-cell mobex-promo-cell--care mobile-overflow-hidden">
                <div class="mobex-promo-inner">
                    <p class="mobex-et-heading mobex-et-kicker"><span class="text">{{ trans('blocks.home.save_25_all_one') }}</span></p>
                    <h3 class="mobex-et-heading mobex-et-title"><span class="text">{{ trans('blocks.home.care_kit_title') }}</span></h3>
                    <p class="mobex-et-heading mobex-et-sub"><span class="text">{{ trans('blocks.home.keep_clean_shine') }}</span></p>
                    <a href="{{ shop }}" class="mobex-promo-cta"><span class="text">{{ trans('blocks.home.shop_now') }}</span><span class="mobex-promo-cta-arrow" aria-hidden="true"></span></a>
                </div>
                <div class="mobex-promo-media mobex-promo-media--b14">
                    <div class="et-image"><img src="{{ 'images/mobex-banners/banner14-img.webp'|asset }}" width="702" height="287" alt="" loading="lazy" decoding="async"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="shipping-banner mobex-shipping-banner mobile-overflow-hidden" aria-label="{{ trans('blocks.home.free_shipping_banner') }}">
    <div class="container mobex-shipping-container">
        <div class="mobex-shipping-inner">
            <div class="mobex-shipping-lede">
                <div class="mobex-shipping-line mobex-shipping-line--free">
                    <h3 class="mobex-et-heading mobex-shipping-free"><span class="text">{{ trans('blocks.home.free_shipping_word') }}</span></h3>
                    <h3 class="mobex-et-heading mobex-shipping-sub"><span class="text">{{ trans('blocks.home.shipping_word') }}</span></h3>
                </div>
            </div>
            <div class="mobex-shipping-visual">
                <div class="et-image mobex-shipping-van"><img src="{{ 'images/mobex-banners/banner15-img.webp'|asset }}" width="514" height="273" alt="" loading="lazy" decoding="async"></div>
            </div>
        </div>
    </div>
</section>

<section class="featured-brands mobex-featured-brands" id="featured-brands" aria-labelledby="mobex-fb-heading">
    <div class="container">
        <h4 class="mobex-fb-heading" id="mobex-fb-heading">{{ trans('blocks.home.featured_brands_logos') }}</h4>
        <div class="mobex-fb-carousel" data-mobex-fb-carousel>
            <button type="button" class="mobex-fb-nav mobex-fb-prev" aria-label="{{ trans('blocks.home.fb_prev') }}" data-mobex-fb-prev>
                <i class="fas fa-chevron-left" aria-hidden="true"></i>
            </button>
            <div class="mobex-fb-viewport" data-mobex-fb-viewport>
                <div class="mobex-fb-track" data-mobex-fb-track>
                    {% set brand_svgs = [
                        { file: 'vicma_color.svg', label: 'Vicma' },
                        { file: 'castrol.svg', label: 'Castrol' },
                        { file: 'ravenol-color.svg', label: 'Ravenol' },
                        { file: 'alanko.svg', label: 'Alanko' },
                        { file: 'tricsan.svg', label: 'Tricsan' },
                        { file: 'abakus_color.svg', label: 'Abakus' },
                        { file: 'blic-color.svg', label: 'Blic' },
                        { file: 'bosch-color.svg', label: 'Bosch' },
                        { file: 'dayco-color.svg', label: 'Dayco' },
                        { file: 'leoplast.svg', label: 'Leoplast' },
                        { file: 'stark.svg', label: 'Stark' },
                        { file: 'dt.svg', label: 'DT' },
                        { file: 'ridex-color.svg', label: 'Ridex' },
                        { file: 'petek.svg', label: 'Petec' }
                    ] %}
                    {% set ph = 'images/placeholder.png'|asset %}
                    {% for b in brand_svgs %}
                        <a href="{{ brands_url }}" class="mobex-fb-item" title="{{ b.label }}">
                            <img class="mobex-fb-logo" src="{{ ('images/brands/' ~ b.file)|asset }}" width="120" height="48" alt="{{ b.label }}" loading="eager" decoding="async" onerror="this.onerror=null;this.src='{{ ph }}';">
                        </a>
                    {% endfor %}
                </div>
            </div>
            <button type="button" class="mobex-fb-nav mobex-fb-next" aria-label="{{ trans('blocks.home.fb_next') }}" data-mobex-fb-next>
                <i class="fas fa-chevron-right" aria-hidden="true"></i>
            </button>
        </div>
    </div>
</section>
