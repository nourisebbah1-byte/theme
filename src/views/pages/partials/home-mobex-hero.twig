{# Mobex-style hero slider — included from pages/index.twig only #}
<section class="hero-section mobex-hero">
    <div class="mobex-hero-slider hero-slider">
        <div class="hero-slide mobex-hero-slide active" data-slide="0">
            <div class="hero-slide-bg" style="background-image: url({{ 'images/mobex-slider/slide-1.webp'|asset|json_encode|raw }})"></div>
            <div class="hero-slide-overlay" aria-hidden="true"></div>
            <div class="hero-content">
                <div class="hero-text">
                    <h2>{{ trans('blocks.home.hero_slide_1_title') }}</h2>
                    <p class="hero-tagline">{{ trans('blocks.home.hero_slide_1_tagline') }}</p>
                    <p class="hero-promo-line">{{ trans('blocks.home.hero_slide_1_promo') }}</p>
                    <a href="{{ link('/') }}" class="shop-now-btn">{{ trans('blocks.home.shop_now') }} <i class="sicon-sar"></i></a>
                </div>
                <div class="hero-image mobex-rs-root">
                    <div class="mobex-rs-stage mobex-rs-stage--s1" aria-hidden="true">
                        <div class="mobex-rs-slot mobex-rs-parallax mobex-rs-pxl2 mobex-rs-s1-z6"><img class="mobex-rs-anim mobex-rs-anim-elastic mobex-rs-anim-delay-100" src="{{ 'images/mobex-slider/slider-asset-1.webp'|asset }}" width="353" height="466" alt=""></div>
                        <div class="mobex-rs-slot mobex-rs-parallax mobex-rs-s1-z7"><img class="mobex-rs-anim mobex-rs-anim-elastic" src="{{ 'images/mobex-slider/slider-asset-2.webp'|asset }}" width="696" height="460" alt=""></div>
                        <div class="mobex-rs-slot mobex-rs-parallax mobex-rs-pxl2 mobex-rs-s1-z8"><img class="mobex-rs-anim mobex-rs-anim-sticker" src="{{ 'images/mobex-slider/slider-asset-3.webp'|asset }}" width="110" height="110" alt=""></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="hero-slide mobex-hero-slide" data-slide="1">
            <div class="hero-slide-bg" style="background-image: url({{ 'images/mobex-slider/slide-2.webp'|asset|json_encode|raw }})"></div>
            <div class="hero-slide-overlay" aria-hidden="true"></div>
            <div class="hero-content">
                <div class="hero-text">
                    <h2>{{ trans('blocks.home.hero_slide_2_title') }}</h2>
                    <p class="hero-tagline">{{ trans('blocks.home.hero_slide_2_tagline') }}</p>
                    <p class="hero-promo-line">{{ trans('blocks.home.hero_slide_2_promo') }}</p>
                    <a href="{{ link('/') }}" class="shop-now-btn">{{ trans('blocks.home.shop_now') }} <i class="sicon-sar"></i></a>
                </div>
                <div class="hero-image mobex-rs-root">
                    <div class="mobex-rs-stage mobex-rs-stage--s2" aria-hidden="true">
                        <div class="mobex-rs-slot mobex-rs-parallax mobex-rs-pxl2 mobex-rs-s2-z6"><img class="mobex-rs-anim mobex-rs-anim-elastic mobex-rs-anim-delay-100" src="{{ 'images/mobex-slider/slider-asset-4.webp'|asset }}" width="561" height="566" alt=""></div>
                        <div class="mobex-rs-slot mobex-rs-parallax mobex-rs-s2-z7"><img class="mobex-rs-anim mobex-rs-anim-elastic" src="{{ 'images/mobex-slider/slider-asset-6.webp'|asset }}" width="624" height="458" alt=""></div>
                        <div class="mobex-rs-slot mobex-rs-parallax mobex-rs-pxl2 mobex-rs-s2-z8"><img class="mobex-rs-anim mobex-rs-anim-sticker" src="{{ 'images/mobex-slider/slider-asset-5.webp'|asset }}" width="110" height="110" alt=""></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="hero-slide mobex-hero-slide" data-slide="2">
            <div class="hero-slide-bg" style="background-image: url({{ 'images/mobex-slider/slide-3.webp'|asset|json_encode|raw }})"></div>
            <div class="hero-slide-overlay" aria-hidden="true"></div>
            <div class="hero-content">
                <div class="hero-text">
                    <h2>{{ trans('blocks.home.hero_slide_3_title') }}</h2>
                    <p class="hero-tagline">{{ trans('blocks.home.hero_slide_3_tagline') }}</p>
                    <p class="hero-promo-line">{{ trans('blocks.home.hero_slide_3_promo') }}</p>
                    <a href="{{ link('/') }}" class="shop-now-btn">{{ trans('blocks.home.shop_now') }} <i class="sicon-sar"></i></a>
                </div>
                <div class="hero-image mobex-rs-root">
                    <div class="mobex-rs-stage mobex-rs-stage--s3" aria-hidden="true">
                        <div class="mobex-rs-slot mobex-rs-parallax mobex-rs-s3-z7"><img class="mobex-rs-anim mobex-rs-anim-elastic" src="{{ 'images/mobex-slider/slider-asset-7.webp'|asset }}" width="529" height="525" alt=""></div>
                        <div class="mobex-rs-slot mobex-rs-parallax mobex-rs-pxl2 mobex-rs-s3-z8"><img class="mobex-rs-anim mobex-rs-anim-sticker" src="{{ 'images/mobex-slider/slider-asset-8.webp'|asset }}" width="110" height="110" alt=""></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="hero-slide mobex-hero-slide" data-slide="3">
            <div class="hero-slide-bg" style="background-image: url({{ 'images/mobex-slider/slide-5.webp'|asset|json_encode|raw }})"></div>
            <div class="hero-slide-overlay" aria-hidden="true"></div>
            <div class="hero-content">
                <div class="hero-text">
                    <h2>{{ trans('blocks.home.hero_slide_4_title') }}</h2>
                    <p class="hero-tagline">{{ trans('blocks.home.hero_slide_4_tagline') }}</p>
                    <p class="hero-promo-line">{{ trans('blocks.home.hero_slide_4_promo') }}</p>
                    <a href="{{ link('/') }}" class="shop-now-btn">{{ trans('blocks.home.shop_now') }} <i class="sicon-sar"></i></a>
                </div>
                <div class="hero-image mobex-rs-root">
                    <div class="mobex-rs-stage mobex-rs-stage--s4" aria-hidden="true">
                        <div class="mobex-rs-slot mobex-rs-parallax mobex-rs-s4-z7"><img class="mobex-rs-anim mobex-rs-anim-elastic" src="{{ 'images/mobex-slider/slider-asset-4.webp'|asset }}" width="624" height="458" alt=""></div>
                        <div class="mobex-rs-slot mobex-rs-parallax mobex-rs-pxl2 mobex-rs-s4-z8"><img class="mobex-rs-anim mobex-rs-anim-sticker" src="{{ 'images/mobex-slider/slider-asset-5.webp'|asset }}" width="110" height="110" alt=""></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mobex-hero-controls" aria-label="{{ trans('blocks.home.hero_slider_region') }}">
        <button type="button" class="mobex-hero-nav mobex-hero-prev" aria-label="{{ trans('blocks.home.hero_slider_prev') }}"><i class="fas fa-chevron-left" aria-hidden="true"></i></button>
        <div class="slider-dots mobex-hero-dots" role="tablist" aria-label="{{ trans('blocks.home.hero_slider_dots_label') }}">
            <button type="button" class="dot active" role="tab" aria-selected="true" aria-label="{{ trans('blocks.home.hero_slide_dot_1') }}"></button>
            <button type="button" class="dot" role="tab" aria-selected="false" aria-label="{{ trans('blocks.home.hero_slide_dot_2') }}"></button>
            <button type="button" class="dot" role="tab" aria-selected="false" aria-label="{{ trans('blocks.home.hero_slide_dot_3') }}"></button>
            <button type="button" class="dot" role="tab" aria-selected="false" aria-label="{{ trans('blocks.home.hero_slide_dot_4') }}"></button>
        </div>
        <button type="button" class="mobex-hero-nav mobex-hero-next" aria-label="{{ trans('blocks.home.hero_slider_next') }}"><i class="fas fa-chevron-right" aria-hidden="true"></i></button>
    </div>

    <div class="hero-vehicle-filter">
        <div class="vehicle-filter-form">
            <h5>{{ trans('blocks.home.choose_your_car') }}</h5>
            <div class="vehicle-filter-fields vehicle-filter-fields--2x2">
                <select class="vehicle-select" id="vehicle-brand">
                    <option value="">{{ trans('blocks.home.brand') }}</option>
                </select>
                <select class="vehicle-select" id="vehicle-model" disabled>
                    <option value="">{{ trans('blocks.home.model') }}</option>
                </select>
                <select class="vehicle-select" id="vehicle-year" disabled>
                    <option value="">{{ trans('blocks.home.year') }}</option>
                </select>
                <button type="button" class="vehicle-search-btn" id="vehicle-search-btn">{{ trans('blocks.home.search') }}</button>
            </div>
            <div class="vehicle-filter-or">
                <span>{{ trans('blocks.home.or') }}</span>
            </div>
            <div class="vehicle-filter-vin">
                <input type="text" class="vin-input" placeholder="{{ trans('blocks.home.search_by_vin') }}">
                <button class="vin-search-btn">{{ trans('blocks.home.search') }}</button>
            </div>
        </div>
    </div>
</section>
