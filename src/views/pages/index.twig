        <div class="hero-slider">
            <div class="hero-slide active">
                <div class="hero-image">
                    <img src="{{ 'images/slider.png'|asset }}" alt="Hero Banner" onerror="this.src='{{ 'images/placeholder.png'|asset }}'">
                </div>
                {# Desktop Overlay Images - Right Side #}
                <div class="hero-overlay-images-right-desktop">
                    {# Second image on top #}
                    <div class="hero-overlay-image hero-overlay-image-2">
                        <img src="https://enovathemes.com/mobex/wp-content/uploads/slider-asset-2.webp" alt="Hero Asset 2">
                    </div>
                    {# First image below #}
                    <div class="hero-overlay-image hero-overlay-image-1">
                        <img src="https://enovathemes.com/mobex/wp-content/uploads/slider-asset-1.webp" alt="Hero Asset 1">
                    </div>
                </div>
                <div class="hero-content">
                    <div class="hero-text">
                        <h2>{{ trans('blocks.home.battery_starters') }}</h2>
                        <p>{{ trans('blocks.home.start_batteries_seconds') }}</p>
                        <a href="{{ link('/') }}" class="shop-now-btn">{{ trans('blocks.home.shop_now') }} <i class="sicon-sar"></i></a>
                    </div>
                </div>
                <div class="price-badge">{{ trans('blocks.home.from_price') }}</div>
            </div>
        </div>
        
        {# Mobile Slider with Overlay Images #}
        <div class="hero-section-mobile-slider">
            <div class="hero-overlay-images-right">
                {# Second image on top #}
                <div class="hero-overlay-image hero-overlay-image-2">
                    <img src="https://enovathemes.com/mobex/wp-content/uploads/slider-asset-2.webp" alt="Hero Asset 2">
                </div>
                {# First image below #}
                <div class="hero-overlay-image hero-overlay-image-1">
                    <img src="https://enovathemes.com/mobex/wp-content/uploads/slider-asset-1.webp" alt="Hero Asset 1">
                </div>
            </div>
            <div class="hero-content">
                <div class="hero-text">
                    <h2>{{ trans('blocks.home.battery_starters') }}</h2>
                    <p>{{ trans('blocks.home.start_batteries_seconds') }}</p>
                    <a href="{{ link('/') }}" class="shop-now-btn">{{ trans('blocks.home.shop_now') }} <i class="sicon-sar"></i></a>
                </div>
            </div>
            <div class="price-badge">{{ trans('blocks.home.from_price') }}</div>
        </div>
        
        {# Vehicle Filter - Fixed in Hero Banner #}
        <div class="hero-vehicle-filter">
            <div class="vehicle-filter-form">
                <h5>{{ trans('blocks.home.choose_your_car') }}</h5>
                <div class="vehicle-filter-fields">
                    <select class="vehicle-select" id="vehicle-brand">
                        <option value="">{{ trans('blocks.home.brand') }}</option>
                    </select>
                    <select class="vehicle-select" id="vehicle-model">
                        <option value="">{{ trans('blocks.home.model') }}</option>
                    </select>
                    <select class="vehicle-select" id="vehicle-year">
                        <option value="">{{ trans('blocks.home.year') }}</option>
                    </select>
                    <select class="vehicle-select" id="vehicle-engine">
                        <option value="">{{ trans('blocks.home.engine') }}</option>
                    </select>
                    <select class="vehicle-select" id="vehicle-trim">
                        <option value="">{{ trans('blocks.home.trim') }}</option>
                    </select>
                    <button type="button" class="vehicle-search-btn" id="vehicle-search-btn">{{ trans('blocks.home.search') }}</button>
                </div>
                <div class="vehicle-filter-or">
                    <span>{{ trans('blocks.home.or') }}</span>
                </div>
                <div class="vehicle-filter-vin">
                    <input type="text" class="vin-input" placeholder="{{ trans('blocks.home.search_by_vin') }}">
